<ui:FluentWindow x:Class="GoodbyeDPIManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="GoodbyeDPI Manager" Height="560" Width="760"
        MinHeight="500"
        MinWidth="560"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Icon="appicon.ico">
        

    <Grid>
        <ui:TitleBar Title="GoodbyeDPI Manager" Panel.ZIndex="1" />

        <Grid x:Name="MainView" Margin="0,35,0,0" Visibility="Visible">
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0" Panel.ZIndex="1">
                <ui:Button Icon="{ui:SymbolIcon Settings24}"
                           Appearance="Transparent"
                           Width="36"
                           Height="36"
                           ToolTip="Settings"
                           ToolTipService.InitialShowDelay="700"
                           Click="OpenSettings_Click"/>

                <ui:Button x:Name="CheckUpdatesButton"
                           Icon="{ui:SymbolIcon ArrowClockwise24}"
                           Appearance="Transparent"
                           Width="36"
                           Height="36"
                           Margin="0,8,0,0"
                           ToolTip="Check for updates"
                           ToolTipService.InitialShowDelay="700"
                           Click="CheckUpdates_Click"/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="10,-20,10,0">
                <TextBlock Text="Service Status" FontSize="14" Foreground="#B0B0B0" HorizontalAlignment="Center" Margin="0,0,0,5"/>

                <Border x:Name="StatusBorder" Background="#334CAF50" CornerRadius="8" Padding="25,5" HorizontalAlignment="Center" Margin="0,0,0,30">
                    <TextBlock x:Name="StatusText" Text="CHECKING..." Foreground="#4CAF50" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                </Border>

                <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,10">
                    <ui:Button Content="Start" Icon="{ui:SymbolIcon Play24}" Appearance="Success" MinWidth="100" Padding="15,6" Margin="5" Click="Start_Click"/>
                    <ui:Button Content="Stop" Icon="{ui:SymbolIcon Stop24}" Appearance="Danger" MinWidth="100" Padding="15,6" Margin="5" Click="Stop_Click"/>
                    <ui:Button Content="Restart" Icon="{ui:SymbolIcon ArrowClockwise24}" Appearance="Primary" MinWidth="100" Padding="15,6" Margin="5" Click="Restart_Click"/>
                </WrapPanel>
            </StackPanel>
        </Grid>

        <Grid x:Name="SettingsView" Margin="0,35,0,0" Visibility="Collapsed" Background="#20242B">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="178"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#191D24" Padding="14,14,12,14">
                <StackPanel>
                    <ui:Button Icon="{ui:SymbolIcon ArrowLeft24}"
                               Content="Back"
                               Appearance="Transparent"
                               HorizontalAlignment="Stretch"
                               Padding="10,7"
                               Margin="0,0,0,16"
                               Click="CloseSettings_Click"/>

                    <TextBlock Text="APP SETTINGS"
                               Foreground="#8D96A3"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="10,0,0,8"/>

                    <ui:Button x:Name="StartupNavButton"
                               Tag="Startup"
                               Icon="{ui:SymbolIcon Play24}"
                               Content="Startup"
                               Appearance="Transparent"
                               HorizontalAlignment="Stretch"
                               HorizontalContentAlignment="Left"
                               Padding="10,7"
                               Margin="0,0,0,4"
                               Click="SettingsNav_Click"/>

                    <ui:Button x:Name="ServiceNavButton"
                               Tag="Service"
                               Icon="{ui:SymbolIcon Settings24}"
                               Content="GDPI Service"
                               Appearance="Transparent"
                               HorizontalAlignment="Stretch"
                               HorizontalContentAlignment="Left"
                               Padding="10,7"
                               Margin="0,0,0,4"
                               Click="SettingsNav_Click"/>

                    <ui:Button x:Name="UpdatesNavButton"
                               Tag="Updates"
                               Icon="{ui:SymbolIcon ArrowClockwise24}"
                               Content="Updates"
                               Appearance="Transparent"
                               HorizontalAlignment="Stretch"
                               HorizontalContentAlignment="Left"
                               Padding="10,7"
                               Margin="0,0,0,4"
                               Click="SettingsNav_Click"/>

                    <ui:Button x:Name="BackgroundNavButton"
                               Tag="Background"
                               Icon="{ui:SymbolIcon ArrowClockwise24}"
                               Content="Background"
                               Appearance="Transparent"
                               HorizontalAlignment="Stretch"
                               HorizontalContentAlignment="Left"
                               Padding="10,7"
                               Margin="0,0,0,4"
                               Click="SettingsNav_Click"/>

                    <Border BorderBrush="#2B3039" BorderThickness="0,1,0,0" Margin="0,12,0,12"/>

                    <ui:Button x:Name="AboutNavButton"
                               Tag="About"
                               Icon="{ui:SymbolIcon Clipboard24}"
                               Content="About"
                               Appearance="Transparent"
                               HorizontalAlignment="Stretch"
                               HorizontalContentAlignment="Left"
                               Padding="10,7"
                               Click="SettingsNav_Click"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">
                <ScrollViewer Margin="28,14,28,22"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel MaxWidth="720">
                        <TextBlock Text="Settings"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Margin="0,0,46,6"/>

                        <TextBlock Text="Configure how GoodbyeDPI Manager starts, runs, and stays available in the background."
                                   FontSize="13"
                                   Foreground="#A1A8B3"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,22"/>

                        <Border x:Name="StartupSettingsSection"
                                BorderBrush="#303640"
                                BorderThickness="0,0,0,0"
                                Padding="0"
                                Margin="0"
                                Visibility="Visible">
                            <StackPanel>
                                <TextBlock Text="Startup"
                                           FontSize="26"
                                           Foreground="White"
                                           Margin="0,0,0,16"/>

                                <Border BorderBrush="#303640" BorderThickness="0,0,0,1" Padding="0,0,0,16" Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                            <TextBlock Text="Open app automatically at Windows startup"
                                                       Foreground="#F0F2F5"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="Creates a scheduled task so the app can start without manually opening it."
                                                       Foreground="#A1A8B3"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <CheckBox x:Name="StartupCheckBox"
                                                  Grid.Column="1"
                                                  Click="Settings_Changed"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <Grid x:Name="HideOnStartupContainer">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                        <TextBlock Text="Start hidden in tray"
                                                   Foreground="#F0F2F5"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="Only applies when Windows startup is enabled. The app starts in the background without showing its window."
                                                   Foreground="#A1A8B3"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <CheckBox x:Name="HideOnStartupCheckBox"
                                              Grid.Column="1"
                                              Click="Settings_Changed"
                                              VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border x:Name="ServiceSettingsSection"
                                BorderBrush="#303640"
                                BorderThickness="0,0,0,0"
                                Padding="0"
                                Margin="0"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="GDPI Service"
                                           FontSize="26"
                                           Foreground="White"
                                           Margin="0,0,0,16"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                        <TextBlock Text="Start GoodbyeDPI when this app opens"
                                                   Foreground="#F0F2F5"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="The service will be started automatically when GoodbyeDPI Manager launches."
                                                   Foreground="#A1A8B3"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <CheckBox x:Name="StartServiceCheckBox"
                                              Grid.Column="1"
                                              Click="Settings_Changed"
                                              VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border x:Name="UpdatesSettingsSection"
                                BorderBrush="#303640"
                                BorderThickness="0,0,0,0"
                                Padding="0"
                                Margin="0"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Updates"
                                           FontSize="26"
                                           Foreground="White"
                                           Margin="0,0,0,16"/>

                                <Border BorderBrush="#303640" BorderThickness="0,0,0,1" Padding="0,0,0,16" Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                            <TextBlock Text="Update channel"
                                                       Foreground="#F0F2F5"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="Choose whether update checks use normal stable releases or beta GitHub pre-releases. &#x0a;&#x0a;NOTE: Stable channel is almost always the way to go unless you are beta testing voluntarily or the developer has personally recommended you to install it."
                                                       Foreground="#A1A8B3"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <ComboBox x:Name="UpdateChannelComboBox"
                                                  Grid.Column="1"
                                                  Width="140"
                                                  VerticalAlignment="Center"
                                                  SelectionChanged="UpdateSettings_Changed">
                                            <ComboBoxItem Content="Stable"/>
                                            <ComboBoxItem Content="Beta"/>
                                        </ComboBox>
                                    </Grid>
                                </Border>

                                <StackPanel>
                                    <TextBlock Text="Current update channel"
                                               Foreground="#F0F2F5"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                    <TextBlock x:Name="UpdateChannelSummaryText"
                                               Foreground="#A1A8B3"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"/>

                                    <ui:Button x:Name="UpdatesPageCheckUpdatesButton"
                                               Content="Check now"
                                               Icon="{ui:SymbolIcon ArrowClockwise24}"
                                               Appearance="Primary"
                                               Padding="12,6"
                                               HorizontalAlignment="Left"
                                               Margin="0,14,0,0"
                                               Click="CheckUpdates_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border x:Name="BackgroundSettingsSection"
                                BorderBrush="#303640"
                                BorderThickness="0,0,0,0"
                                Padding="0"
                                Margin="0"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Background"
                                           FontSize="26"
                                           Foreground="White"
                                           Margin="0,0,0,16"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                        <TextBlock Text="Minimize to tray when closed"
                                                   Foreground="#F0F2F5"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="Clicking the close button hides the window instead of exiting the app."
                                                   Foreground="#A1A8B3"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <CheckBox x:Name="BackgroundCheckBox"
                                              Grid.Column="1"
                                              Click="Settings_Changed"
                                              VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <StackPanel x:Name="AboutSettingsSection" Margin="0,0,0,12" Visibility="Collapsed">
                            <TextBlock Text="About"
                                       FontSize="26"
                                       Foreground="White"
                                       Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Version" Foreground="#A1A8B3" Margin="0,0,16,10"/>
                                <TextBlock x:Name="AboutVersionText" Grid.Row="0" Grid.Column="1" Foreground="#F0F2F5" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Install type" Foreground="#A1A8B3" Margin="0,0,16,10"/>
                                <TextBlock x:Name="AboutInstallTypeText" Grid.Row="1" Grid.Column="1" Foreground="#F0F2F5" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Update channel" Foreground="#A1A8B3" Margin="0,0,16,10"/>
                                <TextBlock x:Name="AboutUpdateChannelText" Grid.Row="2" Grid.Column="1" Foreground="#F0F2F5" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Install path" Foreground="#A1A8B3" Margin="0,0,16,0"/>
                                <TextBlock x:Name="AboutInstallPathText" Grid.Row="3" Grid.Column="1" Foreground="#F0F2F5" TextWrapping="Wrap"/>
                            </Grid>

                            <WrapPanel>
                                <ui:Button x:Name="AboutCheckUpdatesButton"
                                           Content="Check for updates"
                                           Icon="{ui:SymbolIcon ArrowClockwise24}"
                                           Appearance="Primary"
                                           Padding="12,6"
                                           Margin="0,0,8,8"
                                           Click="CheckUpdates_Click"/>

                                <ui:Button Content="GitHub release"
                                           Icon="{ui:SymbolIcon Open24}"
                                           Appearance="Secondary"
                                           Padding="12,6"
                                           Margin="0,0,8,8"
                                           Click="OpenGitHubRelease_Click"/>

                                <ui:Button Content="Copy diagnostics"
                                           Icon="{ui:SymbolIcon Clipboard24}"
                                           Appearance="Secondary"
                                           Padding="12,6"
                                           Margin="0,0,8,8"
                                           Click="CopyDiagnostics_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
