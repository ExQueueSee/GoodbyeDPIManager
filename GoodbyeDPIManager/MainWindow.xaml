<ui:FluentWindow x:Class="GoodbyeDPIManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="GoodbyeDPI Manager" Height="520" Width="520" 
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Icon="appicon.ico">
        

    <Grid>
        <ui:TitleBar Title="GoodbyeDPI Manager" Panel.ZIndex="1" />

        <Grid x:Name="MainView" Margin="0,35,0,0" Visibility="Visible">
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0" Panel.ZIndex="1">
                <ui:Button Icon="{ui:SymbolIcon Settings24}"
                           Appearance="Transparent"
                           Width="36"
                           Height="36"
                           ToolTip="Settings"
                           ToolTipService.InitialShowDelay="700"
                           Click="OpenSettings_Click"/>

                <ui:Button x:Name="CheckUpdatesButton"
                           Icon="{ui:SymbolIcon ArrowClockwise24}"
                           Appearance="Transparent"
                           Width="36"
                           Height="36"
                           Margin="0,8,0,0"
                           ToolTip="Check for updates"
                           ToolTipService.InitialShowDelay="700"
                           Click="CheckUpdates_Click"/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="10,-20,10,0">
                <TextBlock Text="Service Status" FontSize="14" Foreground="#B0B0B0" HorizontalAlignment="Center" Margin="0,0,0,5"/>

                <Border x:Name="StatusBorder" Background="#334CAF50" CornerRadius="8" Padding="25,5" HorizontalAlignment="Center" Margin="0,0,0,30">
                    <TextBlock x:Name="StatusText" Text="CHECKING..." Foreground="#4CAF50" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                </Border>

                <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,10">
                    <ui:Button Content="Start" Icon="{ui:SymbolIcon Play24}" Appearance="Success" MinWidth="100" Padding="15,6" Margin="5" Click="Start_Click"/>
                    <ui:Button Content="Stop" Icon="{ui:SymbolIcon Stop24}" Appearance="Danger" MinWidth="100" Padding="15,6" Margin="5" Click="Stop_Click"/>
                    <ui:Button Content="Restart" Icon="{ui:SymbolIcon ArrowClockwise24}" Appearance="Primary" MinWidth="100" Padding="15,6" Margin="5" Click="Restart_Click"/>
                </WrapPanel>
            </StackPanel>
        </Grid>

        <Grid x:Name="SettingsView" Margin="0,35,0,0" Visibility="Collapsed">
            <ui:Button Icon="{ui:SymbolIcon ArrowLeft24}"
               Appearance="Transparent"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Margin="10,10,0,0"
               Click="CloseSettings_Click"/>

            <ScrollViewer Margin="60,12,20,20"
                  VerticalScrollBarVisibility="Auto">
                <StackPanel HorizontalAlignment="Stretch">

                    <TextBlock Text="Settings"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Margin="0,0,0,6"/>

                    <TextBlock Text="Configure how GoodbyeDPI Manager starts, runs, and stays available in the background."
                       FontSize="13"
                       Foreground="#8A8A8A"
                       TextWrapping="Wrap"
                       Margin="0,0,0,18"/>

                    <!-- Startup card -->
                    <Border Background="#202020"
                    BorderBrush="#343434"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16"
                    Margin="0,0,0,12">

                        <StackPanel>
                            <TextBlock Text="Startup"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0,0,0,4"/>

                            <TextBlock Text="Choose what happens when Windows starts."
                               FontSize="12"
                               Foreground="#8A8A8A"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14"/>

                            <CheckBox x:Name="StartupCheckBox"
                              Click="Settings_Changed"
                              Foreground="#D0D0D0"
                              VerticalContentAlignment="Center"
                              Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Open app automatically at Windows startup"
                                       Foreground="#D0D0D0"
                                       TextWrapping="Wrap"/>
                                    <TextBlock Text="Creates a scheduled task so the app can start without manually opening it."
                                       FontSize="12"
                                       Foreground="#8A8A8A"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                                </StackPanel>
                            </CheckBox>

                            <Border x:Name="HideOnStartupContainer"
                            Background="#181818"
                            BorderBrush="#2C2C2C"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="26,0,0,0">

                                <CheckBox x:Name="HideOnStartupCheckBox"
                                  Click="Settings_Changed"
                                  Foreground="#D0D0D0"
                                  VerticalContentAlignment="Center">
                                    <StackPanel>
                                        <TextBlock Text="Start hidden in tray"
                                           Foreground="#D0D0D0"
                                           TextWrapping="Wrap"/>
                                        <TextBlock Text="Only applies when Windows startup is enabled. The app starts in the background without showing its window."
                                           FontSize="12"
                                           Foreground="#8A8A8A"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0"/>
                                    </StackPanel>
                                </CheckBox>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Service card -->
                    <Border Background="#202020"
                    BorderBrush="#343434"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16"
                    Margin="0,0,0,12">

                        <StackPanel>
                            <TextBlock Text="Service"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0,0,0,4"/>

                            <TextBlock Text="Control how the GoodbyeDPI service behaves when the manager app opens."
                               FontSize="12"
                               Foreground="#8A8A8A"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14"/>

                            <CheckBox x:Name="StartServiceCheckBox"
                              Click="Settings_Changed"
                              Foreground="#D0D0D0"
                              VerticalContentAlignment="Center">
                                <StackPanel>
                                    <TextBlock Text="Start GoodbyeDPI when this app opens"
                                       Foreground="#D0D0D0"
                                       TextWrapping="Wrap"/>
                                    <TextBlock Text="The service will be started automatically when GoodbyeDPI Manager launches."
                                       FontSize="12"
                                       Foreground="#8A8A8A"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                                </StackPanel>
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <!-- Background card -->
                    <Border Background="#202020"
                    BorderBrush="#343434"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16"
                    Margin="0,0,0,12">

                        <StackPanel>
                            <TextBlock Text="Background behavior"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0,0,0,4"/>

                            <TextBlock Text="Choose whether closing the window should close the app or keep it available from the system tray."
                               FontSize="12"
                               Foreground="#8A8A8A"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14"/>

                            <CheckBox x:Name="BackgroundCheckBox"
                              Click="Settings_Changed"
                              Foreground="#D0D0D0"
                              VerticalContentAlignment="Center">
                                <StackPanel>
                                    <TextBlock Text="Minimize to tray when closed"
                                       Foreground="#D0D0D0"
                                       TextWrapping="Wrap"/>
                                    <TextBlock Text="Clicking the close button hides the window instead of exiting the app."
                                       FontSize="12"
                                       Foreground="#8A8A8A"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                                </StackPanel>
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <!-- About card -->
                    <Border Background="#202020"
                    BorderBrush="#343434"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16">

                        <StackPanel>
                            <TextBlock Text="About"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0,0,0,14"/>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Version" Foreground="#8A8A8A" Margin="0,0,12,8"/>
                                <TextBlock x:Name="AboutVersionText" Grid.Row="0" Grid.Column="1" Foreground="#D0D0D0" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Install type" Foreground="#8A8A8A" Margin="0,0,12,8"/>
                                <TextBlock x:Name="AboutInstallTypeText" Grid.Row="1" Grid.Column="1" Foreground="#D0D0D0" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Update channel" Foreground="#8A8A8A" Margin="0,0,12,8"/>
                                <TextBlock x:Name="AboutUpdateChannelText" Grid.Row="2" Grid.Column="1" Foreground="#D0D0D0" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Install path" Foreground="#8A8A8A" Margin="0,0,12,0"/>
                                <TextBlock x:Name="AboutInstallPathText" Grid.Row="3" Grid.Column="1" Foreground="#D0D0D0" TextWrapping="Wrap"/>
                            </Grid>

                            <WrapPanel>
                                <ui:Button x:Name="AboutCheckUpdatesButton"
                                  Content="Check updates"
                                  Icon="{ui:SymbolIcon ArrowClockwise24}"
                                  Appearance="Primary"
                                  Padding="12,6"
                                  Margin="0,0,8,8"
                                  Click="CheckUpdates_Click"/>

                                <ui:Button Content="GitHub release"
                                  Icon="{ui:SymbolIcon Open24}"
                                  Appearance="Secondary"
                                  Padding="12,6"
                                  Margin="0,0,8,8"
                                  Click="OpenGitHubRelease_Click"/>

                                <ui:Button Content="Copy diagnostics"
                                  Icon="{ui:SymbolIcon Clipboard24}"
                                  Appearance="Secondary"
                                  Padding="12,6"
                                  Margin="0,0,8,8"
                                  Click="CopyDiagnostics_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</ui:FluentWindow>
