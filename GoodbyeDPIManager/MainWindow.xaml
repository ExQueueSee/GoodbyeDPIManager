<ui:FluentWindow x:Class="GoodbyeDPIManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="GoodbyeDPI Manager" Height="350" Width="450" 
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>
        <ui:TitleBar Title="GoodbyeDPI Manager" Panel.ZIndex="1" />

        <Grid x:Name="MainView" Margin="0,35,0,0" Visibility="Visible">
            <ui:Button Icon="{ui:SymbolIcon Settings24}" Appearance="Transparent" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0" Click="OpenSettings_Click"/>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-20,0,0">
                <TextBlock Text="Service Status" FontSize="14" Foreground="#B0B0B0" HorizontalAlignment="Center" Margin="0,0,0,5"/>

                <Border x:Name="StatusBorder" Background="#334CAF50" CornerRadius="8" Padding="15,5" HorizontalAlignment="Center" Margin="0,0,0,30">
                    <TextBlock x:Name="StatusText" Text="CHECKING..." Foreground="#4CAF50" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <ui:Button Content="Start" Icon="{ui:SymbolIcon Play24}" Appearance="Success" Width="100" Margin="5" Click="Start_Click"/>
                    <ui:Button Content="Stop" Icon="{ui:SymbolIcon Stop24}" Appearance="Danger" Width="100" Margin="5" Click="Stop_Click"/>
                    <ui:Button Content="Restart" Icon="{ui:SymbolIcon ArrowClockwise24}" Appearance="Primary" Width="100" Margin="5" Click="Restart_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Grid x:Name="SettingsView" Margin="0,35,0,0" Visibility="Collapsed">
            <ui:Button Icon="{ui:SymbolIcon ArrowLeft24}" Appearance="Transparent" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0" Click="CloseSettings_Click"/>

            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="60,12,20,0">
                <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,25"/>

                <CheckBox x:Name="StartupCheckBox" Content="Open app automatically at Windows startup (Bypasses UAC)" Click="Settings_Changed" Margin="0,0,0,15" Foreground="#B0B0B0"/>
                <CheckBox x:Name="StartServiceCheckBox" Content="Start GoodbyeDPI when this app opens" Click="Settings_Changed" Margin="0,0,0,15" Foreground="#B0B0B0"/>
                <CheckBox x:Name="BackgroundCheckBox" Content="Minimize to tray when closed" Click="Settings_Changed" Foreground="#B0B0B0"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>